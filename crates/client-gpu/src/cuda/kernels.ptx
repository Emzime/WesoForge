.version 6.0
.target sm_30
.address_size 64

// spin_kernel(u64 buf_ptr, u32 len, u32 iters)
//
// Baseline PTX for broad compatibility (driver JIT).
// - Works for NVIDIA GPUs with compute capability >= 3.0 (Kepler+).
// - Uses only basic integer ops.
// - buf_ptr is a .u64 parameter (Rust passes buf.as_device_ptr().as_raw()).
.visible .entry spin_kernel(
    .param .u64 buf_ptr,
    .param .u32 len,
    .param .u32 iters
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<12>;
    .reg .b64   %rd<10>;

    ld.param.u64 %rd1, [buf_ptr];
    ld.param.u32 %r1,  [len];
    ld.param.u32 %r2,  [iters];

    mov.u32 %r3, %tid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %ntid.x;
    mad.lo.u32 %r0, %r4, %r5, %r3;

    setp.ge.u32 %p0, %r0, %r1;
    @%p0 bra DONE;

    mul.wide.u32 %rd2, %r0, 4;
    add.u64 %rd3, %rd1, %rd2;

    ld.global.u32 %r6, [%rd3];

LOOP:
    mad.lo.u32 %r6, %r6, 1664525, 1013904223;
    add.u32 %r2, %r2, -1;
    setp.ne.u32 %p1, %r2, 0;
    @%p1 bra LOOP;

    st.global.u32 [%rd3], %r6;

DONE:
    ret;
}
